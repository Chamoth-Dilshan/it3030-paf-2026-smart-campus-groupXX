# Frontend environment template
# Copy to .env.local for local development overrides

# Base URL for API requests used by src/services/api.js
VITE_API_BASE_URL=http://localhost:8080/api

# Base backend URL used for OAuth redirect entrypoint in login page
VITE_BACKEND_URL=http://localhost:8080

# Show Google login button only when backend OAuth is configured
VITE_GOOGLE_OAUTH_ENABLED=false
