# Smart Campus project ignores

# Environment and local configuration
.env
.env.*
!.env.example
*.local
application-local.properties
application-*.local.properties

# Secrets and certificates
*.pem
*.key
*.crt
*.p12
*.pfx

# Logs and runtime output
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
hs_err_pid*
replay_pid*

# Java / Spring Boot / Maven
target/
*.class
*.jar
*.war
*.ear
*.nar
dependency-reduced-pom.xml
.mvn/timing.properties
compile_output.txt

# Node / Vite / frontend builds
node_modules/
dist/
dist-ssr/
build/
coverage/
.vite/
.eslintcache

# Test and coverage reports
surefire-reports/
failsafe-reports/
test-output/
*.lcov

# Uploaded/generated files
**/uploads/**
!uploads/
!uploads/README.md

# IDEs and editors
.idea/
*.iws
*.iml
*.ipr
.classpath
.factorypath
.project
.settings/
.apt_generated/
.springBeans
.sts4-cache/
nbproject/private/
nbbuild/
nbdist/
.nb-gradle/

# Keep shared VS Code workspace files, ignore personal workspace state
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/extensions.json

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# Archives and packaged artifacts
*.zip
*.tar
*.tar.gz
*.tgz
*.rar
*.7z

# Temporary files
*.tmp
*.temp
*.swp
*.swo
*~
