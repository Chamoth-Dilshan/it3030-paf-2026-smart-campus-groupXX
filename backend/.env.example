# MongoDB
SPRING_MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/smart_campus_db?retryWrites=true&w=majority
SPRING_DATA_MONGODB_URI=${SPRING_MONGODB_URI}

# Server
SERVER_PORT=8080

# JWT
JWT_SECRET=replace-with-a-long-random-secret-key
JWT_EXPIRATION=86400000

# Google OAuth 2.0
APP_OAUTH_GOOGLE_ENABLED=true
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
