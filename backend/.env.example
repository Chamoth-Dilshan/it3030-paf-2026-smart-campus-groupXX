# MongoDB
# URL-encode special characters in the password, then authenticate Atlas users via admin.
SPRING_MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/smart_campus_db?authSource=admin&retryWrites=true&w=majority
SPRING_DATA_MONGODB_URI=${SPRING_MONGODB_URI}

# Spring profile
# Use local for development, prod only for deployed/production environments.
SPRING_PROFILES_ACTIVE=local

# Server
SERVER_PORT=8080

# JWT
JWT_SECRET=replace-with-a-long-random-secret-key
JWT_EXPIRATION=86400000

# Seed data
APP_SEED_ENABLED=true
APP_SEED_DEFAULT_PASSWORD=Password@123

# Google OAuth 2.0
APP_OAUTH_GOOGLE_ENABLED=true
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
